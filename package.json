{
  "name": "1paste",
  "version": "1.0.0",
  "type": "module",
  "description": "Zero-knowledge, burn-after-read secret sharing on Cloudflare Workers. End-to-end encrypted in the browser. The server only ever stores ciphertext. Live at https://1paste.dev",
  "homepage": "https://1paste.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/r87-e/1paste.dev.git"
  },
  "bugs": {
    "url": "https://github.com/r87-e/1paste.dev/issues"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:fonts": "node scripts/build-fonts.mjs",
    "dryrun": "wrangler deploy --dry-run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pastebin",
    "zero-knowledge",
    "end-to-end-encryption",
    "burn-after-reading",
    "one-time-secret",
    "self-destructing-messages",
    "password-sharing",
    "cloudflare-workers",
    "durable-objects",
    "aes-gcm",
    "webcrypto",
    "privacy",
    "encrypted-paste",
    "secure-share",
    "edge-computing",
    "typescript",
    "hono",
    "open-source"
  ],
  "author": "r87-e",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.19",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@vitest/runner": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.5"
  }
}
